# The worker talks to the server over HTTPS only (claim jobs, heartbeat, segments,
# results) — no Redis connection, so no REDIS_URL. The cluster firewall allowing only
# 80/443 outbound is therefore fine.
SERVER_BASE_URL=https://your-moodlepro-server.example.com
INTERNAL_API_TOKEN=change-me-to-a-long-random-secret
FAKE_TRANSCRIBE=true
MODEL_NAME=ivrit-ai/whisper-large-v3-turbo-ct2
DEVICE=cuda
COMPUTE_TYPE=float16
LANGUAGE=he

# Liveness heartbeat (TTL must comfortably exceed the interval).
HEARTBEAT_INTERVAL_SECONDS=10
HEARTBEAT_TTL_SECONDS=30
