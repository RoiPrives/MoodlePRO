# Copy to deploy/.env and fill in. NEVER commit the real .env.
# Generate secrets with:  openssl rand -hex 32

# --- Domain / HTTPS (Caddy gets a free Let's Encrypt cert for this name) ---
DOMAIN=moodlepro.example.com               # real DNS name pointing at the VM's public IP (DuckDNS works)
PUBLIC_BASE_URL=https://moodlepro.example.com

# --- Postgres ---
POSTGRES_USER=moodlepro
POSTGRES_PASSWORD=CHANGE_ME_long_random
POSTGRES_DB=moodlepro

# --- Redis (internet-facing; password is mandatory) ---
REDIS_PASSWORD=CHANGE_ME_long_random

# --- Shared secret between the server and the cluster worker (must match ~/.moodlepro.env) ---
INTERNAL_API_TOKEN=CHANGE_ME_long_random

# --- Groq fallback (ROTATE the key shared in chat) ---
GROQ_API_KEY=gsk_...
GROQ_MODEL=whisper-large-v3
GROQ_FALLBACK_GRACE_SECONDS=90
